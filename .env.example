# Supabase Postgres connection
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/voulezvous

# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/voulezvous

# Spool directories
SPOOL_ROOT=/spool

# Streaming target – RTMP URL or "null" for test sink
STREAM_TARGET=null

# Fallback video file path (relative to SPOOL_ROOT/fallback/)
FALLBACK_VIDEO=fallback.mp4

# Prep worker: how many hours ahead to prepare
PREP_LOOKAHEAD_HOURS=6

# Delete local bytes after successful stream
DELETE_AFTER_STREAM=true

# API admin token (empty = no auth for local dev)
ADMIN_TOKEN=

# FFmpeg binary path
FFMPEG_PATH=ffmpeg

# House format defaults
HOUSE_VIDEO_CODEC=libx264
HOUSE_AUDIO_CODEC=aac
HOUSE_RESOLUTION=1920x1080
HOUSE_FRAME_RATE=30
HOUSE_AUDIO_SAMPLE_RATE=48000

# HLS settings
HLS_SEGMENT_DURATION=6
HLS_PLAYLIST_SIZE=10

# Cloudflare R2 (for CDN delivery)
# All heavy processing stays local; R2 just serves HLS segments
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=voulezvous-hls
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_PUBLIC_URL=

# Log level
LOG_LEVEL=INFO

# ============================================================
# Acquisition subsystem
# ============================================================

# Local LLM inference endpoint (Ollama default)
# Used for enrichment, keyword expansion, lineup polish
# Falls back to deterministic heuristics if unavailable
LOCAL_LLM_URL=http://localhost:11434

# Browser profiles directory (persisted logged sessions)
BROWSER_PROFILES_DIR=/spool/browser_profiles
